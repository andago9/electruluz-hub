/**
 * Config pública del build. Este archivo SÍ se versiona en git: no pongas secretos.
 * La contraseña del panel (VITE_KEYSTATIC_PASSWORD) y el Basic Auth opcional van en .env.local.
 */

/** Ruta pública del sitio. "/" = raíz del dominio (public_html). */
VITE_BASE_PATH=/
/** URL absoluta de producción (sin barra final). Ej: https://www.ferreteriaelectroluz.com */
VITE_SITE_URL=https://www.ferreteriaelectroluz.com
